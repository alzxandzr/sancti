{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "paths": {
      "@sancti/lib/*": [
        "../lib/*"
      ],
      "@sancti/types/*": [
        "../types/*"
      ],
      "@sancti/prompts/*": [
        "../prompts/*"
      ],
      "@sancti/data/*": [
        "../data/*"
      ]
    }
  },
  "include": [
    "app/**/*",
    "types/**/*",
    "../types/**/*",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
