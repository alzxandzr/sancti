{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "api/**/*",
    "app/**/*",
    "lib/**/*",
    "server/**/*",
    "tests/**/*",
    "theme/**/*",
    "components/**/*",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
