# ─── Server-side (Next.js API routes / EAS build) ───────────────────────────
# Never bundle these into the mobile app. Provided via Vercel project env or
# EAS secrets.
ANTHROPIC_API_KEY=sk-ant-...

# Model routing (override only to pin a specific revision; defaults shipped in lib/env.ts).
ANTHROPIC_MODEL_CLASSIFY=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SAFETY=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_PLAN=claude-sonnet-4-6

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...

LITCAL_API_BASE=https://litcal.johnromanodorazio.com/api/dev/

# Observability (optional in dev, required for production).
SENTRY_DSN=https://example@sentry.io/...
POSTHOG_API_KEY=phc_...

LOG_LEVEL=info
NODE_ENV=development

# ─── Public / mobile (EXPO_PUBLIC_* are bundled into the Expo app) ──────────
# Safe-to-ship values only. Do NOT put service role keys here.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=ey...
EXPO_PUBLIC_API_BASE_URL=https://sancti.app/api
EXPO_PUBLIC_SENTRY_DSN=https://example@sentry.io/...
EXPO_PUBLIC_POSTHOG_API_KEY=phc_...
