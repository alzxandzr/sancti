# ─── Server-side (Expo Router API routes, never bundled into the client) ───
# Provided via Vercel project env in production. API routes degrade to a
# "no LLM configured" response when GEMINI_API_KEY is missing.
GEMINI_API_KEY=AIza...

# Model routing (override only to pin a specific revision; defaults in server/lib/env.ts).
GEMINI_MODEL_CLASSIFY=gemini-2.5-flash
GEMINI_MODEL_SAFETY=gemini-2.5-flash
GEMINI_MODEL_PLAN=gemini-2.5-flash
# Used when the primary plan model returns 429/RESOURCE_EXHAUSTED.
# flash-lite has a separate quota bucket on the free tier.
GEMINI_MODEL_PLAN_FALLBACK=gemini-2.5-flash-lite

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...

LITCAL_API_BASE=https://litcal.johnromanodorazio.com/api/dev/

# Observability (optional in dev, required for production).
SENTRY_DSN=https://example@sentry.io/...
POSTHOG_API_KEY=phc_...

LOG_LEVEL=info
NODE_ENV=development

# ─── Public (EXPO_PUBLIC_*) ─────────────────────────────────────────────────
# Bundled into every client target (web + iOS + Android). Safe-to-ship values
# only — never put service role keys here.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Web is same-origin, so this only matters for native (Expo Go / iOS / Android).
# Point it at the deployed Vercel URL or a tunnel for local-on-device dev.
EXPO_PUBLIC_API_BASE_URL=https://sancti-expo.vercel.app/api
EXPO_PUBLIC_SENTRY_DSN=https://example@sentry.io/...
EXPO_PUBLIC_POSTHOG_API_KEY=phc_...
